---
import { client } from '../lib/sanity';

let testimonials = [];
let stats = { total: 0, average: 0 };
try {
  testimonials = await client.fetch(
    `*[_type == "testimonial" && featured == true] | order(date desc)[0...6]{
      name,
      text,
      rating,
      date
    }`
  );

  const allRatings: number[] = await client.fetch(`*[_type == "testimonial" && defined(rating)].rating`);
  if (allRatings && allRatings.length > 0) {
    const sum = allRatings.reduce((a, b) => a + b, 0);
    const avg = sum / allRatings.length;
    stats.total = allRatings.length;
    stats.average = Math.round(avg * 10) / 10;
  }
} catch (e) {
  console.warn('Could not fetch testimonials', e);
}
---

{testimonials.length > 0 && (
  <section class="section testimonials-section">
    <div class="container">
      <h2 class="text-center testimonial-title">Was unsere Klient:innen sagen</h2>
      {stats.total > 0 && (
        <p class="text-center testimonial-stats">
          <span class="stars-icon">&#9733;</span> <strong style="font-size: 1.3rem;">{Number(stats.average).toFixed(1)}</strong> ({stats.total} Bewertungen)
        </p>
      )}
      
      <div class="testimonials-slider">
        {testimonials.length > 1 && (
          <button type="button" class="slider-btn prev" aria-label="Vorherige Bewertung">&#10094;</button>
        )}

        <div class="slider-track-container">
          <div class="slider-track">
            {testimonials.map((t: any, index: number) => (
              <div class="testimonial-slide" data-index={index}>
                <div class="testimonial-card">
                  {t.rating && (
                    <div class="stars" aria-label={`${t.rating} von 5 Sternen`}>
                      {Array.from({ length: 5 }).map((_: any, i: number) => (
                        <span class={i < t.rating ? 'star filled' : 'star'}>&#9733;</span>
                      ))}
                    </div>
                  )}
                  <blockquote class="testimonial-text">&laquo;{t.text}&raquo;</blockquote>
                  <div class="testimonial-author">
                    <span class="author-name">{t.name}</span>
                    {t.date && (
                      <span class="testimonial-date">
                        {new Date(t.date).toLocaleDateString('de-CH', { year: 'numeric', month: 'long' })}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        
        {testimonials.length > 1 && (
          <button type="button" class="slider-btn next" aria-label="Nächste Bewertung">&#10095;</button>
        )}

        {testimonials.length > 1 && (
          <div class="slider-dots">
            {testimonials.map((_: any, i: number) => (
              <button type="button" class="dot" aria-label={`Gehe zu Bewertung ${i + 1}`}></button>
            ))}
          </div>
        )}
      </div>

      <div class="text-center" style="margin-top: 2rem;">
        <a href="/bewertung" class="btn" style="background-color: transparent; border: 2px solid var(--color-primary); color: var(--color-primary); padding: 0.8rem 2rem;">Bewertung abgeben</a>
      </div>

    </div>
  </section>
)}

<style>
  .testimonials-section {
    background-color: var(--color-primary-light);
    padding-top: 4rem; /* Reduced from global var(--spacing-xl) which is 8rem */
    padding-bottom: 2rem;
  }

  /* Remove footer margin gap globally when this component is present */
  :global(footer) {
    margin-top: 0 !important;
  }

  .testimonial-title {
    font-size: 2.2rem;
    margin-bottom: var(--spacing-xs);
  }

  .testimonial-stats {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  
  .testimonial-stats strong {
    color: var(--color-text);
  }

  .stars-icon {
    color: #FFB300;
    font-size: 1.2rem;
  }

  .testimonials-slider {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-xs) 3rem 1rem;
  }

  .slider-track-container {
    overflow: hidden;
  }

  .slider-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .testimonial-slide {
    flex: 0 0 100%;
    width: 100%;
    padding: 0 var(--spacing-sm);
    box-sizing: border-box;
  }

  .testimonial-card {
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stars {
    margin-bottom: var(--spacing-sm);
  }

  .star {
    font-size: 1.4rem;
    color: #ddd;
    margin: 0 2px;
  }

  .star.filled {
    color: var(--color-primary);
  }

  .testimonial-text {
    font-family: var(--font-quote);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .testimonial-author {
    font-weight: 500;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .author-name {
    font-size: 1.05rem;
    color: var(--color-text);
  }

  .testimonial-date {
    font-weight: 300;
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .slider-btn {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background: none;
    border: none;
    font-size: 1.8rem;
    color: var(--color-text-light);
    opacity: 0.5;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s, opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .slider-btn.prev {
    left: 0;
  }

  .slider-btn.next {
    right: 0;
  }

  .slider-btn:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d5d5d5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s, transform 0.3s;
  }

  .dot:hover {
    background: #bbb;
  }

  .dot.active {
    background: var(--color-primary);
    transform: scale(1.2);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const sliders = document.querySelectorAll('.testimonials-slider');
    
    sliders.forEach(slider => {
      const track = slider.querySelector('.slider-track') as HTMLElement;
      if (!track) return;
      
      const slides = track.querySelectorAll('.testimonial-slide');
      const dots = slider.querySelectorAll('.dot');
      const prevBtn = slider.querySelector('.slider-btn.prev');
      const nextBtn = slider.querySelector('.slider-btn.next');
      
      if (slides.length <= 1) return;

      let currentIndex = 0;
      let intervalId: number;

      function goToSlide(index: number) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;
        currentIndex = index;
        
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

      function nextSlide() { goToSlide(currentIndex + 1); }
      function prevSlide() { goToSlide(currentIndex - 1); }

      prevBtn?.addEventListener('click', () => { prevSlide(); resetInterval(); });
      nextBtn?.addEventListener('click', () => { nextSlide(); resetInterval(); });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { goToSlide(i); resetInterval(); });
      });

      function startInterval() {
        intervalId = window.setInterval(nextSlide, 8000); // 8 seconds per slide
      }

      function resetInterval() {
        window.clearInterval(intervalId);
        startInterval();
      }

      // Initialize first slide and start autoplay
      goToSlide(0);
      startInterval();
    });
  });
</script>
