---
import Layout from '../layouts/Layout.astro';

// Get URL params for error/success handling
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<Layout title="Bewertung abgeben - Physiotherapie Alke van Leeuwen">
  <section class="section" style="padding-top: 2rem;">
    <div class="container max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h1 class="mb-4">Ihre Erfahrung bei uns</h1>
        <p class="text-lg text-gray-600">
          Ihre Meinung ist uns sehr wichtig! Wir freuen uns, wenn Sie sich kurz Zeit nehmen, 
          um Ihre Behandlung in unserer Praxis zu bewerten.
        </p>
      </div>

      {success === '1' ? (
        <div class="success-message">
          <div class="success-icon">&#10004;</div>
          <h3>Vielen Dank für Ihre Bewertung!</h3>
          <p>Wir haben Ihr Feedback erhalten. Es wird nach einer kurzen Prüfung auf unserer Website veröffentlicht.</p>
          <a href="/" class="btn mt-6 inline-block">Zurück zur Startseite</a>
        </div>
      ) : (
        <form action="/api/submit-review" method="POST" class="review-form" data-astro-reload>
          {error && (
            <div class="error-banner">
              <strong>Fehler:</strong> {error === 'cms' ? 'Systemfehler beim Speichern. Bitte versuchen Sie es später erneut.' : decodeURIComponent(error)}
            </div>
          )}

          <!-- Honeypot -->
          <div style="position: absolute; left: -5000px;" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" value="">
          </div>

          <div class="form-group">
            <label for="name">Ihr Name (wie er angezeigt werden soll) *</label>
            <input type="text" id="name" name="name" required placeholder="z.B. Anna M.">
          </div>

          <div class="form-group">
            <label>Wie zufrieden waren Sie? *</label>
            <div class="star-rating margin-top-xs">
              <div class="stars-container" id="stars-container">
                <input type="radio" id="star5" name="rating" value="5" /><label for="star5" title="5 Sterne"></label>
                <input type="radio" id="star4" name="rating" value="4" /><label for="star4" title="4 Sterne"></label>
                <input type="radio" id="star3" name="rating" value="3" /><label for="star3" title="3 Sterne"></label>
                <input type="radio" id="star2" name="rating" value="2" /><label for="star2" title="2 Sterne"></label>
                <input type="radio" id="star1" name="rating" value="1" /><label for="star1" title="1 Stern"></label>
              </div>
              <span id="rating-value-display" class="rating-text">Bitte wählen</span>
            </div>
          </div>

          {/* Custom Date Picker */}
          <div class="form-group" style="position: relative;">
            <label>Datum Ihres Besuchs / der Behandlung *</label>
            <input type="date" id="date" name="date" required class="datum-native" />
            <div class="datepicker" id="datepicker">
              <button type="button" class="datepicker-trigger" id="datepicker-trigger">
                <span id="datepicker-display">Datum wählen</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
                </svg>
              </button>
              <div class="datepicker-dropdown" id="datepicker-dropdown">
                <div class="datepicker-header">
                  <button type="button" class="datepicker-nav" id="dp-prev" aria-label="Vorheriger Monat">&lsaquo;</button>
                  <span class="datepicker-month" id="dp-month-label"></span>
                  <button type="button" class="datepicker-nav" id="dp-next" aria-label="Nächster Monat">&rsaquo;</button>
                </div>
                <div class="datepicker-weekdays">
                  <span>Mo</span><span>Di</span><span>Mi</span><span>Do</span><span>Fr</span><span>Sa</span><span>So</span>
                </div>
                <div class="datepicker-days" id="dp-days"></div>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="text">Ihre Bewertung *</label>
            <textarea id="text" name="text" rows="5" required placeholder="Teilen Sie uns und anderen mit, wie Sie die Behandlung empfunden haben..."></textarea>
          </div>

          <hr class="my-8" style="border:0; border-top: 1px solid #eee;" />
          
          <h3 class="mb-4 text-xl">Kontaktaufnahme (Optional)</h3>
          <p class="text-sm text-gray-500 mb-4">Geben Sie hier Ihre E-Mail Adresse an, falls wir Sie exklusiv bei Fragen zu Ihrem Feedback kontaktieren dürfen. Diese wird <strong>nicht</strong> veröffentlicht.</p>
          
          <div class="form-group">
            <label for="email">E-Mail Adresse (intern)</label>
            <input type="email" id="email" name="email" placeholder="ihre@email.ch">
          </div>

          <div class="form-group checkbox-group" id="contact-request-group">
            <input type="checkbox" id="contactRequested" name="contactRequested">
            <label for="contactRequested">Ich wünsche, dass mich die Praxis gegebenenfalls kontaktiert.</label>
          </div>

          <button type="submit" class="btn btn-primary w-full mt-6" style="padding: 1rem; font-size: 1.1rem;">Bewertung absenden</button>
        </form>
      )}
    </div>
  </section>
</Layout>

<style>
  .review-form {
    background: #fff;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }
  
  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="date"],
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid #ddd;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-text);
    background-color: #fafafa;
    transition: all 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background-color: #fff;
    box-shadow: 0 0 0 3px rgba(235, 105, 11, 0.1);
  }

  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: var(--radius-sm);
    border: 1px solid #eee;
    transition: opacity 0.3s;
  }
  
  .checkbox-group label {
    margin-bottom: 0;
    font-weight: 400;
    cursor: pointer;
  }

  .checkbox-group input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }
  
  .checkbox-group.disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  /* Star Rating System using CSS trick (right to left float) */
  .star-rating {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .rating-text {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-light);
    min-width: 60px;
  }

  .stars-container {
    display: flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
  }

  .stars-container input {
    display: none;
  }

  .stars-container label {
    box-sizing: border-box;
    display: inline-block;
    padding: 0;
    font-size: 2.5rem;
    color: #ddd;
    cursor: pointer;
    line-height: 1;
    margin: 0 !important;
  }

  .stars-container label::before {
    content: '★'; /* solid star */
    display: inline-block;
  }

  /* Hover and Checked states */
  .stars-container label:hover,
  .stars-container label:hover ~ label,
  .stars-container input:checked ~ label {
    color: #FFB300 !important;
  }

  /* Success Message */
  .success-message {
    background: #fff;
    padding: 3rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .success-icon {
    font-size: 4rem;
    color: #48bb78;
    margin-bottom: 1rem;
  }

  .success-message h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .error-banner {
    background-color: #fff5f5;
    color: #c53030;
    padding: 1rem;
    border-radius: var(--radius-sm);
    border-left: 4px solid #f56565;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .review-form {
      padding: 1.5rem;
    }
    .datepicker-dropdown {
      width: 100% !important;
    }
  }

  /* Hide native inputs when JS custom components are active */
  .hidden {
    display: none !important;
  }

  /* ===== Custom Date Picker ===== */
  .datepicker {
    display: none;
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .datepicker.active {
    display: block;
  }

  .datepicker-trigger {
    width: 100%;
    box-sizing: border-box;
    padding: 0.8rem 1rem;
    border: 1px solid #ddd;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-text-light);
    background: #fafafa;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s ease;
  }

  .datepicker-trigger:hover {
    border-color: var(--color-primary);
  }

  .datepicker-trigger:focus {
    outline: none;
    border-color: var(--color-primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(235, 105, 11, 0.1);
  }

  .datepicker-trigger.has-value {
    color: var(--color-text);
  }

  .datepicker-trigger svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .datepicker-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 100;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-float);
    padding: 1rem;
    width: 320px;
    max-width: 100%;
    box-sizing: border-box;
  }

  .datepicker-dropdown.open {
    display: block;
  }

  .datepicker-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .datepicker-month {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .datepicker-nav {
    background: none;
    border: 1px solid #e5e5e5;
    border-radius: var(--radius-sm);
    width: 32px;
    height: 32px;
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all 0.15s ease;
  }

  .datepicker-nav:hover:not(:disabled) {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .datepicker-nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .datepicker-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .datepicker-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  /* Dynamic elements */
  .datepicker-days :global(.dp-day) {
    width: 100%;
    aspect-ratio: 1;
    border: none;
    background: none;
    border-radius: 50%;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    color: var(--color-text);
    transition: all 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 0;
  }

  .datepicker-days :global(.dp-day:hover:not(:disabled):not(.dp-empty)) {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  .datepicker-days :global(.dp-day.dp-disabled) {
    color: #d5d5d5;
    cursor: not-allowed;
  }

  .datepicker-days :global(.dp-day.dp-today:not(.dp-selected)) {
    font-weight: 600;
    border: 1px solid var(--color-primary);
  }

  .datepicker-days :global(.dp-day.dp-selected) {
    background: var(--color-primary);
    color: #fff;
    font-weight: 500;
  }

  .datepicker-days :global(.dp-empty) {
    cursor: default;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // 1. Custom Date Picker Logic
    const datepicker = document.getElementById('datepicker');
    const trigger = document.getElementById('datepicker-trigger');
    const dropdown = document.getElementById('datepicker-dropdown');
    const display = document.getElementById('datepicker-display');
    const daysContainer = document.getElementById('dp-days');
    const monthLabel = document.getElementById('dp-month-label');
    const prevBtn = document.getElementById('dp-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('dp-next') as HTMLButtonElement;
    const nativeDateInput = document.getElementById('date') as HTMLInputElement;

    if (datepicker && nativeDateInput) {
      nativeDateInput.classList.add('hidden');
      datepicker.classList.add('active');

      const todayDate = new Date();
      todayDate.setHours(0,0,0,0);
      
      let viewMonth = todayDate.getMonth();
      let viewYear = todayDate.getFullYear();
      let selectedDate: string | null = null;
      
      if (!nativeDateInput.value) {
        const todayStr = `${todayDate.getFullYear()}-${String(todayDate.getMonth() + 1).padStart(2, '0')}-${String(todayDate.getDate()).padStart(2, '0')}`;
        nativeDateInput.value = todayStr;
        selectedDate = todayStr;
        if (display) {
          display.textContent = todayDate.toLocaleDateString('de-CH', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' });
        }
        if (trigger) trigger.classList.add('has-value');
      } else {
        selectedDate = nativeDateInput.value;
        const sd = new Date(selectedDate);
        if (display) display.textContent = sd.toLocaleDateString('de-CH', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' });
        if (trigger) trigger.classList.add('has-value');
      }

      const MONTHS_DE = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];

      function renderCalendar() {
        if (!monthLabel || !daysContainer) return;
        monthLabel.textContent = `${MONTHS_DE[viewMonth]} ${viewYear}`;
        daysContainer.innerHTML = '';

        const firstDay = new Date(viewYear, viewMonth, 1);
        let startDay = firstDay.getDay() - 1;
        if (startDay < 0) startDay = 6;

        const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

        for (let i = 0; i < startDay; i++) {
          const empty = document.createElement('span');
          empty.className = 'dp-day dp-empty';
          daysContainer.appendChild(empty);
        }

        for (let d = 1; d <= daysInMonth; d++) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'dp-day';
          btn.textContent = d.toString();

          const cellDate = new Date(viewYear, viewMonth, d);
          const dateStr = `${viewYear}-${String(viewMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;

          // Disable future dates
          if (cellDate > todayDate) {
            btn.disabled = true;
            btn.classList.add('dp-disabled');
          }

          if (selectedDate === dateStr) {
            btn.classList.add('dp-selected');
          }

          if (cellDate.getTime() === todayDate.getTime()) {
            btn.classList.add('dp-today');
          }

          btn.addEventListener('click', (e) => {
            e.preventDefault();
            selectedDate = dateStr;
            if (nativeDateInput) nativeDateInput.value = dateStr;
            if (display) display.textContent = cellDate.toLocaleDateString('de-CH', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' });
            if (trigger) trigger.classList.add('has-value');
            if (dropdown) dropdown.classList.remove('open');
            renderCalendar();
          });

          daysContainer.appendChild(btn);
        }

        if (nextBtn) {
          nextBtn.disabled = (viewYear === todayDate.getFullYear() && viewMonth >= todayDate.getMonth()) || viewYear > todayDate.getFullYear();
        }
      }

      if (trigger && dropdown) {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          dropdown.classList.toggle('open');
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', (e) => {
          e.preventDefault();
          viewMonth--;
          if (viewMonth < 0) { viewMonth = 11; viewYear--; }
          renderCalendar();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', (e) => {
          e.preventDefault();
          viewMonth++;
          if (viewMonth > 11) { viewMonth = 0; viewYear++; }
          renderCalendar();
        });
      }

      document.addEventListener('click', (e) => {
        if (datepicker && dropdown && e.target && !datepicker.contains(e.target as Node)) {
          dropdown.classList.remove('open');
        }
      });

      renderCalendar();
    }

    // 2. Star Text Display Logic
    const starsInputs = document.querySelectorAll('.stars-container input[type="radio"]');
    const ratingDisplay = document.getElementById('rating-value-display');
    
    if (starsInputs.length > 0 && ratingDisplay) {
      starsInputs.forEach(input => {
        input.addEventListener('change', (e) => {
          const val = (e.target as HTMLInputElement).value;
          ratingDisplay.textContent = val + ' / 5';
          ratingDisplay.style.color = '#333';
        });
      });
    }

    // 3. Email Checkbox Logic
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const checkboxGroup = document.getElementById('contact-request-group');
    const contactRequested = document.getElementById('contactRequested') as HTMLInputElement;

    function evaluateEmail() {
      if (!emailInput || !checkboxGroup || !contactRequested) return;
      
      const val = emailInput.value.trim();
      const isValidish = val.includes('@') && val.includes('.');
      
      if (isValidish) {
        checkboxGroup.classList.remove('disabled');
        contactRequested.disabled = false;
      } else {
        checkboxGroup.classList.add('disabled');
        contactRequested.disabled = true;
        contactRequested.checked = false;
      }
    }

    if (emailInput) {
      // Initial state
      evaluateEmail();
      // On changes
      emailInput.addEventListener('input', evaluateEmail);
    }
  });
</script>
